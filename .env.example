# Database
POSTGRES_USER=bpuser
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=bp_tracker

# Timezone (used for reminder scheduling)
TZ=Asia/Kolkata

# Web port exposed on your NAS
WEB_PORT=3005

# Frontend API path (leave as /api when using bundled nginx proxy)
VITE_API_URL=/api

# Blood pressure reminder times (24h format, local timezone)
BP_MORNING_TIME=08:00
BP_AFTERNOON_TIME=14:00
BP_EVENING_TIME=20:00

# Walking reminder if steps below threshold by this time
WALKING_REMINDER_TIME=18:00
MIN_DAILY_STEPS=5000

# Web Push (generate with: docker compose run --rm api python -m app.generate_vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: ntfy.sh topic for phone notifications (install ntfy app, subscribe to topic)
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
